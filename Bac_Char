# Make new files for quality check of raw data
%%bash

mkdir -p raw_fastqc

for sample in SAMP071 SAMP074 SAMP099 SAMP100
do
  fastqc ${sample}_1.fastq ${sample}_2.fastq -o raw_fastqc
done


# fastp trimming
%%bash
set -uo pipefail

mkdir -p trimmed_fastq fastp_reports fastqc_trimmed

for sample in SAMP071 SAMP074 SAMP099 SAMP100
do
  r1=${sample}_1.fastq
  r2=${sample}_2.fastq

  out1=trimmed_fastq/${sample}_1.trim.fastq.gz
  out2=trimmed_fastq/${sample}_2.trim.fastq.gz

  fastp \
    -i "$r1" -I "$r2" \
    -o "$out1" -O "$out2" \
    --detect_adapter_for_pe \
    --cut_front --cut_tail \
    --cut_window_size 4 --cut_mean_quality 20 \
    --length_required 30 \
    --thread 4 \
    --html fastp_reports/${sample}.fastp.html \
    --json fastp_reports/${sample}.fastp.json

  fastqc "$out1" "$out2" -o fastqc_trimmed
done

# Indexing (preliminary)
%%bash
set -uo pipefail

# Join all .fa files into a large reference file
find representatives/ -name "*.fa" -print0 | xargs -0 cat > combined_reference.fasta
echo "New reference file created"

# Set variable to the new file
REF="combined_reference.fasta"

# Indexing for BWA
echo "Starting indexing for BWA"
bwa index $REF
echo "BWA indexing done"

# Indexing for Bowtie2
echo "Starting indexing for Bowtie2"
bowtie2-build $REF bowtie2_index
echo "Bowtie2 indexing done"

# Indexing for Minimap2
echo "Starting indexing for Minimap2"
minimap2 -d minimap2_index.mmi $REF
echo "Minimap2 indexing done"

echo "Indexing complete"
